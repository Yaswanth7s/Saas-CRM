## Server
PORT=5000
NODE_ENV=development

## MongoDB
# Option A (local MongoDB):
# MONGO_URI=mongodb://127.0.0.1:27017/crm
#
# Option B (MongoDB Atlas):
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/crm?retryWrites=true&w=majority
MONGO_URI=

## Frontend URL (CORS)
CLIENT_URL=http://localhost:5173

## Secrets (use long random strings in real deployments)
COOKIE_SECRET=change-me-cookie-secret
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

## Optional
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
